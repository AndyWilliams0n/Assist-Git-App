{
  "llm": {
    "providers": {
      "openai": {
        "model": "gpt-5.4-mini"
      },
      "anthropic": {
        "model": "claude-4-6-sonnet-latest",
        "max_tokens": 4000
      }
    },
    "functions": {
      "jira_description_generation": {
        "openai_model": "gpt-5.4-mini",
        "anthropic_model": "claude-4-6-sonnet-latest"
      },
      "git_content_generation": {
        "openai_model": "gpt-5.4-mini",
        "anthropic_model": "claude-4-6-sonnet-latest"
      }
    }
  },
  "vision": {
    "model": "gpt-5.4-mini",
    "max_images_per_turn": 2,
    "max_image_bytes": 8388608,
    "timeout_seconds": 20
  },
  "agents": {
    "orchestrator": {
      "model": "gpt-5.4-mini"
    },
    "planner": {
      "model": "gpt-5.4-mini"
    },
    "research": {
      "model": "gpt-5.4-mini"
    },
    "jira_api": {
      "bypass": false
    },
    "git_content": {
      "model": "gpt-5.4-mini"
    },
    "code_builder_codex": {
      "model": "gpt-5.3-codex",
      "bypass": false
    },
    "code_review": {
      "model": "gpt-5.3-codex",
      "bypass": false
    },
    "cli_agent": {
      "model": "gpt-5.4-mini"
    },
    "logging_agent": {
      "model": "gpt-5.4-mini"
    }
  },
  "git_workflow": {
    "workflows": {
      "chat": {
        "settings": {
          "defaultBranch": "__active_workspace_branch__",
          "branchNamePattern": "feature/{description}",
          "commitMessagePattern": "feat: {description}",
          "prTitlePattern": "feat: {description}",
          "prBodyTemplate": "## Summary\n\n{description}\n\n## Changes\n\n- \n\n## Test Plan\n\n- ",
          "platform": "auto",
          "autoDetect": true,
          "autoPushOnCommit": false
        },
        "phases": [
          {
            "id": "initial",
            "label": "Pre-Intent / Pipeline Start",
            "description": "Runs before Chat Intent Router or before Pipeline Agent starts a task run.",
            "agentName": [
              "Orchestrator Agent",
              "Pipeline Agent"
            ],
            "icon": "play",
            "gitAction": {
              "type": "none",
              "enabled": false,
              "branchNamePattern": "{ticket}",
              "reuseExistingBranch": true,
              "commitMessagePattern": "feat: {description}",
              "targetBranch": "main",
              "prTitlePattern": "feat: {description}",
              "prBodyTemplate": "## Summary\n\n{description}\n\n## Changes\n\n- ",
              "draft": false,
              "pushBeforePr": true,
              "customCommand": ""
            },
            "secondaryGitAction": {
              "type": "none",
              "enabled": false,
              "branchNamePattern": "feature/{description}",
