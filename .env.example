# Model settings
# Required: API keys for enabled providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model overrides
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_MODEL=claude-haiku-4-5
# Anthropic generation cap
ANTHROPIC_MAX_TOKENS=1200

# LLM retry/timeouts
LLM_TIMEOUT_SECONDS=60
LLM_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1.0
LLM_RETRY_MAX_BACKOFF_SECONDS=8.0
LLM_RETRY_JITTER_SECONDS=0.25

# Workspace + DB
WORKSPACE_ROOT=
# postgres (default) or sqlite
DB_BACKEND=postgres
DATABASE_URL=postgresql://localhost/assistant
SQLITE_PATH=./assistant.db
# Keep enabled unless troubleshooting stale connections
DB_CONN_PRE_PING=true

# GitHub
GITHUB_TOKEN=
GITHUB_USERNAME=

# GitLab
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_USERNAME=

# Shared PAT aliases (optional fallback when provider token is unset)
GIT_SHARED_PAT=
ASSIST_GIT_PAT=
